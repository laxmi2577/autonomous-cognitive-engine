# ─────────────────────────────────────────────
# Autonomous Cognitive Engine — Environment Config
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# Required: Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# LLM Configuration (default works fine, no need to change)
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.4

# Optional: LangSmith tracing at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=autonomous-cognitive-engine
